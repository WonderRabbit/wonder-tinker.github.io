---
import BaseLayout from "../layouts/BaseLayout.astro"

const title = "404 | Wonder Tinker"
const description = "The requested Wonder Tinker page was not found."
const baseUrl = new URL(import.meta.env.BASE_URL, Astro.site ?? "https://wonder-tinker.github.io")
const homeHref = new URL("", baseUrl).pathname
const blogHref = new URL("blog/", baseUrl).pathname
---

<BaseLayout title={title} description={description} canonicalPath="/404.html">
  <main id="main" class="site-shell page-stack">
    <section class="page-header not-found" aria-labelledby="not-found-heading">
      <p class="eyebrow">404</p>
      <h1 id="not-found-heading">Page not found</h1>
      <p class="lede">
        The route does not exist in the current static build. Return to the blog index or
        the home page.
      </p>
      <div class="action-row">
        <a class="text-link" href={homeHref}>Home</a>
        <a class="text-link" href={blogHref}>Blog</a>
      </div>
    </section>
  </main>
</BaseLayout>
